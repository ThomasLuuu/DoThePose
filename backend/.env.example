# Copy to .env and adjust.

PORT=3000
NODE_ENV=development

UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed
DATABASE_PATH=./data/guides.db

# Local ONNX line-art (informative-drawings). Default: ./models/model.onnx under cwd.
# Download: https://huggingface.co/rocca/informative-drawings-line-art-onnx/resolve/main/model.onnx
LINE_ART_ONNX_PATH=

# Optional: legacy Gradio HTTP (no longer used by pipeline portrait mode)
# GRADIO_INFORMATIVE_DRAWINGS_URL=
