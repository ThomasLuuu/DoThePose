# Copy to .env and adjust.

PORT=3000
NODE_ENV=development

UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed
DATABASE_PATH=./data/guides.db

# Local ONNX line-art (informative-drawings). Default: ./models/model.onnx under cwd.
# Download: https://huggingface.co/rocca/informative-drawings-line-art-onnx/resolve/main/model.onnx
LINE_ART_ONNX_PATH=

# Optional: legacy Gradio HTTP (no longer used by pipeline portrait mode)
# GRADIO_INFORMATIVE_DRAWINGS_URL=

# ── Queue / Worker tuning ──────────────────────────────────────────────────
# Number of jobs processed concurrently (per-job workers OR pool size).
# Default: 2. Increase gradually under load; each slot uses significant RAM.
JOB_QUEUE_MAX_CONCURRENT=2

# Set to "true" to use the persistent worker pool instead of per-job workers.
# With the pool, ONNX sessions stay warm between jobs — reduces cold-start
# latency on consecutive requests. Requires ONNX model to be present at startup.
WORKER_POOL_ENABLED=false
